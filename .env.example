# Copy to .env and fill in real values. Never commit .env.

DISCORD_BOT_TOKEN=your-discord-bot-token-here
ANTHROPIC_API_KEY=sk-ant-...

# Generate with: openssl rand -hex 32
# You define this — the Joplin container configures itself with whatever value you set here.
JOPLIN_API_TOKEN=

# One-time Dropbox OAuth token for Joplin sync.
# Obtain via:
#   docker compose run --rm joplin sh
#   joplin config sync.target 7
#   joplin sync          # follow the browser auth prompt
#   joplin config sync.7.auth   # copy this output
#   exit
# Then paste the JSON blob below (keep the single quotes to preserve special chars).
JOPLIN_DROPBOX_AUTH=
